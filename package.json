{
  "name": "e-hentai-helper",
  "version": "0.8.2",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:prod": "node scripts/build.mjs --prod",
    "build:watch": "node scripts/build.mjs --watch",
    "addon:build": "npm run build && npx web-ext build --source-dir addon --artifacts-dir dist --overwrite-dest",
    "addon:dev": "dotenv -e .env -e .env.defaults -- npx web-ext run --source-dir addon --firefox-profile ./.web-ext-profile --profile-create-if-missing --keep-profile-changes",
    "dev": "npm run build && concurrently -k \"npm:build:watch\" \"npm:addon:dev\"",
    "addon:lint": "npx web-ext lint --source-dir addon --self-hosted",
    "addon:sign": "npx web-ext sign --source-dir addon --artifacts-dir dist --channel unlisted --api-key \"$AMO_JWT_ISSUER\" --api-secret \"$AMO_JWT_SECRET\"",
    "release:notes": "node scripts/release-notes.mjs",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build && npm run addon:lint && npm run addon:build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.{ts,tsx} scripts/**/*.mjs test/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "web-ext": "^10.4.0"
  },
  "dependencies": {
    "@preact/signals": "^2.9.2",
    "preact": "^10.29.3"
  }
}
