{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/hooks/format.mjs"],
            "statusMessage": "Prettier フォーマット中...",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "node",
            "args": [".claude/hooks/lint.mjs"],
            "statusMessage": "ESLint チェック中...",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/hooks/test-on-stop.mjs"],
            "statusMessage": "テスト実行中...",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
